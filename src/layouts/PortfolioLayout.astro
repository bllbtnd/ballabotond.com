---
/**
 * PortfolioLayout.astro
 * 
 * Global layout shell for the single-page portfolio.
 * Configures Lenis smooth scrolling, loads premium typography,
 * and sets up the light monochrome aesthetic.
 */
import { getLangFromUrl, languages, type Languages } from '../i18n/utils';
import { ClientRouter } from 'astro:transitions';
import CookieBanner from '../components/CookieBanner.astro';
import WeatherTheme from '../components/WeatherTheme.astro';
import '@fontsource/space-grotesk/300.css';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/instrument-serif/400.css';
import '@fontsource/instrument-serif/400-italic.css';
import { SITE_CONFIG, SCHEMA_SAME_AS_LINKS } from '../config/constants';
import { generateBaseSchema, generateAlternateLinks, LOCALE_MAP, HREFLANG_MAP } from '../utils/seo';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  canonical?: string;
}

const lang = getLangFromUrl(Astro.url) as Languages;

const {
  title = SITE_CONFIG.title,
  description = SITE_CONFIG.description,
  keywords = 'Balla Botond, software engineer, computer science, portfolio, bllbtnd',
  ogImage = '/assets/images/profile.webp',
  canonical = Astro.url.pathname
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();
const siteTitle = "Balla Botond";
const author = "Balla Botond";
const siteUrl = "https://ballabotond.com";
const currentLocale = LOCALE_MAP[lang] || 'en_US';
const supportedLocaleKeys = Object.keys(languages);
const alternateLinks = generateAlternateLinks(Astro.url.pathname, supportedLocaleKeys, siteUrl);

const stripLocaleFromPath = (pathname: string) => {
  const segments = pathname.split('/');
  const potentialLocale = segments[1];
  if (potentialLocale && supportedLocaleKeys.includes(potentialLocale)) {
    const rest = segments.slice(2).join('/');
    return rest ? `/${rest}` : '/';
  }
  return pathname || '/';
};

const defaultLocalePath = stripLocaleFromPath(Astro.url.pathname);
const defaultAlternateHref = new URL(defaultLocalePath, siteUrl).toString();
const siteLanguages = supportedLocaleKeys.map((code) => HREFLANG_MAP[code] || code);
const baseSchema = generateBaseSchema(siteLanguages);
---

<!DOCTYPE html>
<html lang={lang} dir="ltr" class="lenis lenis-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <!-- Resource Hints -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={author} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />
    {alternateLinks.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hrefLang} href={alternate.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={defaultAlternateHref} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, siteUrl).toString()} />
    <meta property="og:locale" content={currentLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@bllbtnd" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, siteUrl).toString()} />

    <!-- Theme -->
    <meta name="theme-color" content="#F0EBE3" />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Structured Data -->
    <script type="application/ld+json" is:inline>
      {JSON.stringify(baseSchema)}
    </script>

    <!-- GA4 Consent Mode v2 — must run before gtag loads -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('consent', 'default', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        functionality_storage: 'denied',
        personalization_storage: 'denied',
        security_storage: 'granted',
        wait_for_update: 800,
      });
      if (localStorage.getItem('cookie_consent') === 'accepted') {
        gtag('consent', 'update', { analytics_storage: 'granted' });
      }
    </script>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-3NZN7X2WL9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-3NZN7X2WL9');
    </script>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />

    <ClientRouter />

    <style is:global>
      /* ============================================
         CSS CUSTOM PROPERTIES — Weather-Adaptive Palette
         Registered with @property for smooth animated
         transitions between weather / time-of-day themes.
         ============================================ */

      @property --pf-bg {
        syntax: '<color>';
        inherits: true;
        initial-value: #F0EBE3;
      }
      @property --pf-text {
        syntax: '<color>';
        inherits: true;
        initial-value: #1A1A1A;
      }
      @property --pf-accent {
        syntax: '<color>';
        inherits: true;
        initial-value: #7A6C5D;
      }
      @property --pf-accent-light {
        syntax: '<color>';
        inherits: true;
        initial-value: #9B8E7E;
      }
      @property --pf-muted {
        syntax: '<color>';
        inherits: true;
        initial-value: #B8B2A8;
      }
      @property --pf-border {
        syntax: '<color>';
        inherits: true;
        initial-value: #E5E2DC;
      }
      @property --pf-surface {
        syntax: '<color>';
        inherits: true;
        initial-value: #F0EDE8;
      }

      /* Default palette — day-clear */
      :root {
        --pf-bg: #F0EBE3;
        --pf-text: #1A1A1A;
        --pf-accent: #7A6C5D;
        --pf-accent-light: #9B8E7E;
        --pf-muted: #B8B2A8;
        --pf-border: #E5E2DC;
        --pf-surface: #F0EDE8;

        /* Animate theme transitions via registered @property */
        transition:
          --pf-bg 2s cubic-bezier(0.4, 0, 0.2, 1),
          --pf-text 2s cubic-bezier(0.4, 0, 0.2, 1),
          --pf-accent 1.5s cubic-bezier(0.4, 0, 0.2, 1),
          --pf-accent-light 1.5s cubic-bezier(0.4, 0, 0.2, 1),
          --pf-muted 1.5s cubic-bezier(0.4, 0, 0.2, 1),
          --pf-border 1.5s cubic-bezier(0.4, 0, 0.2, 1),
          --pf-surface 1.5s cubic-bezier(0.4, 0, 0.2, 1);
      }

      /* ─── Dawn ─── */
      html[data-wx="dawn"] {
        --pf-bg: #F5E8D0; --pf-text: #1C0F06;
        --pf-accent: #C4762C; --pf-accent-light: #E09050;
        --pf-muted: #B0804A; --pf-border: #EBD8B8; --pf-surface: #F8EDD8;
      }
      /* ─── Dusk ─── */
      html[data-wx="dusk"] {
        --pf-bg: #F2D8B8; --pf-text: #180A02;
        --pf-accent: #C06030; --pf-accent-light: #E08050;
        --pf-muted: #A87050; --pf-border: #E4C8A0; --pf-surface: #F8E0C4;
      }

      /* ─── Day variants ─── */
      html[data-wx="day-clear"] {
        --pf-bg: #F0EBE3; --pf-text: #1A1A1A;
        --pf-accent: #7A6C5D; --pf-accent-light: #9B8E7E;
        --pf-muted: #B8B2A8; --pf-border: #E5E2DC; --pf-surface: #F0EDE8;
      }
      html[data-wx="day-cloudy"] {
        --pf-bg: #E5E1DA; --pf-text: #1A1A1A;
        --pf-accent: #6A6059; --pf-accent-light: #8A8078;
        --pf-muted: #A8A49E; --pf-border: #D8D4CE; --pf-surface: #EDEAE4;
      }
      html[data-wx="day-fog"] {
        --pf-bg: #E8E3DC; --pf-text: #252318;
        --pf-accent: #7A7568; --pf-accent-light: #9A9488;
        --pf-muted: #ACA89E; --pf-border: #DEDAD4; --pf-surface: #ECEAE5;
      }
      html[data-wx="day-drizzle"] {
        --pf-bg: #E0E5E9; --pf-text: #182028;
        --pf-accent: #507088; --pf-accent-light: #7090A8;
        --pf-muted: #8898A8; --pf-border: #CDD5DC; --pf-surface: #E8ECF0;
      }
      /* Rain: dark, heavy, slate-blue */
      html[data-wx="day-rain"] {
        --pf-bg: #C5D0DB; --pf-text: #090F18;
        --pf-accent: #364F68; --pf-accent-light: #527090;
        --pf-muted: #6080A0; --pf-border: #AABBC8; --pf-surface: #CDD8E3;
      }
      /* Snow: bright, crisp, icy white-blue */
      html[data-wx="day-snow"] {
        --pf-bg: #F0F5FC; --pf-text: #18203A;
        --pf-accent: #4858B0; --pf-accent-light: #6878D0;
        --pf-muted: #8090C8; --pf-border: #CCD8F0; --pf-surface: #F8FBFF;
      }
      html[data-wx="day-thunder"] {
        --pf-bg: #C8D0D8; --pf-text: #0C1520;
        --pf-accent: #304858; --pf-accent-light: #506878;
        --pf-muted: #607880; --pf-border: #B0BCC8; --pf-surface: #D5DDE5;
      }

      /* ─── Night variants ─── */
      html[data-wx="night-clear"] {
        --pf-bg: #0F1117; --pf-text: #E5E0D8;
        --pf-accent: #8B7F6E; --pf-accent-light: #B0A090;
        --pf-muted: #5A5550; --pf-border: #1E2230; --pf-surface: #151824;
      }
      html[data-wx="night-cloudy"] {
        --pf-bg: #111110; --pf-text: #DDD8D0;
        --pf-accent: #887870; --pf-accent-light: #A8988E;
        --pf-muted: #585450; --pf-border: #1C1C1A; --pf-surface: #1A1918;
      }
      html[data-wx="night-fog"] {
        --pf-bg: #100F0C; --pf-text: #D0CCC4;
        --pf-accent: #807068; --pf-accent-light: #A08C7C;
        --pf-muted: #504840; --pf-border: #1E1C18; --pf-surface: #181714;
      }
      html[data-wx="night-drizzle"] {
        --pf-bg: #0D1016; --pf-text: #C8D4DC;
        --pf-accent: #406080; --pf-accent-light: #6080A0;
        --pf-muted: #3C5068; --pf-border: #141C28; --pf-surface: #10151E;
      }
      /* Night rain: deep dark slate */
      html[data-wx="night-rain"] {
        --pf-bg: #070A10; --pf-text: #B8C8D8;
        --pf-accent: #2C4460; --pf-accent-light: #486080;
        --pf-muted: #284058; --pf-border: #0E141E; --pf-surface: #0A0D14;
      }
      /* Night snow: dark but noticeably lighter and bluer */
      html[data-wx="night-snow"] {
        --pf-bg: #12182A; --pf-text: #D8E8FF;
        --pf-accent: #5870C0; --pf-accent-light: #7890E0;
        --pf-muted: #4060A8; --pf-border: #1E2A48; --pf-surface: #18203C;
      }
      html[data-wx="night-thunder"] {
        --pf-bg: #080A10; --pf-text: #B8C0CC;
        --pf-accent: #283440; --pf-accent-light: #405060;
        --pf-muted: #283040; --pf-border: #0C1018; --pf-surface: #0A0C14;
      }

      /* Fog overlay */
      html[data-wx-effect="fog"] body::after {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 995;
        background: radial-gradient(ellipse at center, transparent 30%, rgba(200, 195, 185, 0.25) 100%);
        backdrop-filter: blur(1px);
      }

      /* ─── Image tinting — weather-adaptive ─── */
      img, video {
        transition: filter 2s cubic-bezier(0.4, 0, 0.2, 1);
      }

      /* Dawn: warm golden lift */
      html[data-wx="dawn"] img,
      html[data-wx="dawn"] video {
        filter: brightness(1.05) saturate(1.15) sepia(0.18);
      }
      /* Dusk: amber warmth */
      html[data-wx="dusk"] img,
      html[data-wx="dusk"] video {
        filter: brightness(0.98) saturate(1.1) sepia(0.25) hue-rotate(-8deg);
      }
      /* Day clear: default, no filter */
      html[data-wx="day-clear"] img,
      html[data-wx="day-clear"] video {
        filter: none;
      }
      /* Day cloudy: slightly desaturated */
      html[data-wx="day-cloudy"] img,
      html[data-wx="day-cloudy"] video {
        filter: saturate(0.88) brightness(0.98);
      }
      /* Fog: hazy desaturated */
      html[data-wx="day-fog"] img,
      html[data-wx="day-fog"] video,
      html[data-wx="night-fog"] img,
      html[data-wx="night-fog"] video {
        filter: saturate(0.7) brightness(0.92) blur(0.3px);
      }
      /* Drizzle & rain: cool desaturated */
      html[data-wx="day-drizzle"] img,
      html[data-wx="day-drizzle"] video {
        filter: saturate(0.82) brightness(0.97) hue-rotate(8deg);
      }
      /* Rain: dark, heavy, desaturated blue */
      html[data-wx="day-rain"] img,
      html[data-wx="day-rain"] video {
        filter: brightness(0.85) saturate(0.62) hue-rotate(18deg);
      }
      /* Snow: bright, crisp, almost monochrome with cold cast */
      html[data-wx="day-snow"] img,
      html[data-wx="day-snow"] video {
        filter: brightness(1.1) saturate(0.38) hue-rotate(200deg) contrast(0.95);
      }
      /* Thunder: dramatic contrast */
      html[data-wx="day-thunder"] img,
      html[data-wx="day-thunder"] video {
        filter: saturate(0.6) brightness(0.85) contrast(1.08);
      }
      /* Night clear: subtle cool tint */
      html[data-wx="night-clear"] img,
      html[data-wx="night-clear"] video {
        filter: brightness(0.9) saturate(0.88) hue-rotate(8deg);
      }
      /* Night cloudy */
      html[data-wx="night-cloudy"] img,
      html[data-wx="night-cloudy"] video {
        filter: brightness(0.86) saturate(0.82);
      }
      /* Night drizzle & rain: dark, heavy */
      html[data-wx="night-drizzle"] img,
      html[data-wx="night-drizzle"] video {
        filter: brightness(0.82) saturate(0.7) hue-rotate(10deg);
      }
      html[data-wx="night-rain"] img,
      html[data-wx="night-rain"] video {
        filter: brightness(0.78) saturate(0.62) hue-rotate(15deg);
      }
      /* Night snow: brighter, icy, heavily desaturated */
      html[data-wx="night-snow"] img,
      html[data-wx="night-snow"] video {
        filter: brightness(0.95) saturate(0.32) hue-rotate(200deg) contrast(0.9);
      }
      /* Night thunder */
      html[data-wx="night-thunder"] img,
      html[data-wx="night-thunder"] video {
        filter: brightness(0.78) saturate(0.65) contrast(1.05);
      }

      /* ============================================
         PORTFOLIO GLOBAL STYLES
         Digital Sobriety. Zero decorative borders.
         Structure via negative space + asymmetric grid.
         ============================================ */

      /* Lenis overrides */
      html.lenis, html.lenis body {
        height: auto;
      }
      .lenis.lenis-smooth {
        scroll-behavior: auto !important;
      }
      .lenis.lenis-smooth [data-lenis-prevent] {
        overscroll-behavior: contain;
      }
      .lenis.lenis-stopped {
        overflow: hidden;
      }

      /* Base typography & body */
      html {
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        text-rendering: optimizeLegibility;
        font-feature-settings: 'kern' 1, 'liga' 1;
      }

      body {
        font-family: 'Space Grotesk', system-ui, sans-serif;
        background-color: var(--pf-bg);
        color: var(--pf-text);
        overflow-x: clip;
        transition: background-color 2s cubic-bezier(0.4, 0, 0.2, 1), color 2s cubic-bezier(0.4, 0, 0.2, 1);
      }

      /* Hide scrollbar globally while preserving scroll */
      html,
      body {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }

      html::-webkit-scrollbar,
      body::-webkit-scrollbar {
        display: none;
      }

      /* Selection color */
      ::selection {
        background-color: var(--pf-accent);
        color: var(--pf-bg);
      }

      /* Reduced motion fallback */
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
          scroll-behavior: auto !important;
        }
        .motion-reduce-hidden {
          opacity: 1 !important;
          transform: none !important;
        }
      }

      /* Portfolio utility classes */
      .pf-serif {
        font-family: 'Instrument Serif', 'Playfair Display', Georgia, serif;
      }
      .pf-grotesk {
        font-family: 'Space Grotesk', system-ui, sans-serif;
      }

      /* Smooth link underlines */
      .pf-link {
        position: relative;
        display: inline-block;
      }
      .pf-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1px;
        background-color: currentColor;
        transition: width 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .pf-link:hover::after {
        width: 100%;
      }

      /* Horizontal rule style */
      .pf-divider {
        height: 1px;
        background-color: var(--pf-border);
        border: none;
        transition: background-color 1.5s cubic-bezier(0.4, 0, 0.2, 1);
      }
    </style>

    <slot name="head" />
  </head>
  <body>
    <slot />

    <!-- Cookie consent banner -->
    <CookieBanner />

    <!-- Weather-adaptive theming + consent -->
    <WeatherTheme />

    <!-- Lenis Smooth Scroll Initialization -->
    <script>
      import Lenis from 'lenis';
      import 'lenis/dist/lenis.css';

      let lenis: InstanceType<typeof Lenis> | null = null;

      function initLenis() {
        if (lenis) {
          lenis.destroy();
          lenis = null;
        }

        // Respect prefers-reduced-motion
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReducedMotion) return;

        // Skip Lenis on touch devices — native scroll is smoother
        const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
        if (isTouchDevice) return;

        lenis = new Lenis({
          autoRaf: true,
          lerp: 0.08,
          smoothWheel: true,
          wheelMultiplier: 0.8,
        });
      }

      initLenis();
      document.addEventListener('astro:after-swap', initLenis);

      // Listen for reduced motion preference changes
      window.matchMedia('(prefers-reduced-motion: reduce)').addEventListener('change', (e) => {
        if (e.matches && lenis) {
          lenis.destroy();
          lenis = null;
        } else if (!e.matches && !lenis) {
          initLenis();
        }
      });
    </script>
  </body>
</html>
