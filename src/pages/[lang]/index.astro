---
/**
 * [lang]/index.astro — single-page portfolio homepage.
 * Editorial / Atelier design: numbered sections, hairline rules,
 * monumental serif typography. Zero client-side frameworks.
 */
import PortfolioLayout from '../../layouts/PortfolioLayout.astro';
import { useTranslations, useTranslatedPath, languages, defaultLang } from '../../i18n/utils';
import { SOCIAL_LINKS } from '../../config/constants';

import Nav from '../../components/portfolio/Nav.astro';
import Intro from '../../components/portfolio/Intro.astro';
import ScrollRail from '../../components/portfolio/ScrollRail.astro';
import Hero from '../../components/portfolio/Hero.astro';
import Story from '../../components/portfolio/Story.astro';
import Resume from '../../components/portfolio/Resume.astro';
import Projects from '../../components/portfolio/Projects.astro';
import Footer from '../../components/portfolio/Footer.astro';

import { getImage } from 'astro:assets';
import profileImageSrc from '../../assets/images/profile.webp';
import storyPortraitSrc from '../../assets/images/story-portrait.webp';

import projects from '../../data/projects.json';

// Direct imports for array access (t() only returns strings)
import en from '../../i18n/en.json';
import hu from '../../i18n/hu.json';
import it from '../../i18n/it.json';
const allTranslations = { en, hu, it } as Record<string, any>;

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;
const typedLang = lang as keyof typeof languages;
const t = useTranslations(typedLang);
const translatePath = useTranslatedPath(typedLang);
const siteOrigin = Astro.site ?? 'https://ballabotond.com';
const pageUrl = new URL(Astro.url.pathname, siteOrigin).toString();

// ── Optimized images ─────────────────────────────────
const optimizedProfile = await getImage({
  src: profileImageSrc,
  width: 720,
  height: 960,
  fit: 'cover',
  format: 'webp',
});

const optimizedStoryPortrait = await getImage({
  src: storyPortraitSrc,
  width: 1200,
  height: 1179,
  format: 'webp',
});

const heroImage = `${siteOrigin}/assets/images/profile.webp`;
const canonicalUrl = new URL(`/${lang}/`, siteOrigin).toString();

// ── Structured data ────────────────────────────────────
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${pageUrl}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: t('common.name'), item: pageUrl }
  ]
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${pageUrl}#webpage`,
  url: pageUrl,
  name: t('home.title'),
  description: t('home.description'),
  inLanguage: typedLang,
  isPartOf: { '@id': `${siteOrigin}#website` },
  about: { '@id': `${siteOrigin}#person` },
  primaryImageOfPage: {
    '@type': 'ImageObject',
    '@id': `${heroImage}#primaryimage`,
    url: heroImage,
    width: 1200,
    height: 1200,
    caption: t('common.name')
  },
  mainEntity: { '@id': `${siteOrigin}#person` },
  breadcrumb: { '@id': `${pageUrl}#breadcrumb` }
};

const structuredData = [breadcrumbSchema, webPageSchema];

// ── Life Story Data ────────────────────────────────────
const lifeStoryParagraphs: string[] =
  allTranslations[typedLang]?.resume?.lifeStory?.paragraphs ??
  allTranslations[defaultLang]?.resume?.lifeStory?.paragraphs ??
  [];

// ── Nav sections ───────────────────────────────────────
const navSections = [
  { id: 'story', label: t('resume.lifeStory.title') },
  { id: 'resume', label: t('nav.resume') },
  { id: 'projects', label: t('nav.projects') },
  { id: 'contact', label: t('portfolio.contact') },
];

// ── Resume Data ────────────────────────────────────────
const experienceEntries = [
  {
    year: t('resume.experience.current_period'),
    title: t('resume.experience.current'),
    company: t('resume.experience.current_company'),
    companyUrl: 'https://logicloud.hu',
    description: [
      t('resume.experience.current_desc1'),
      t('resume.experience.current_desc2'),
    ],
    isCurrent: true,
  },
  {
    year: t('resume.experience.intern_period'),
    title: t('resume.experience.intern'),
    company: t('resume.experience.intern_company'),
    companyUrl: 'https://logicloud.hu',
    description: [
      t('resume.experience.intern_desc1'),
    ],
  },
];

const educationEntries = [
  {
    year: t('resume.education.university_period'),
    title: t('resume.education.university'),
    company: t('resume.education.university_school'),
    companyUrl: 'https://pte.hu',
    description: [
      t('resume.education.university_desc1'),
      t('resume.education.university_desc2'),
    ],
    isCurrent: true,
  },
  {
    year: t('resume.education.drivers_license_period'),
    title: t('resume.education.drivers_license'),
    company: t('resume.education.drivers_license_school'),
    description: [t('resume.education.drivers_license_desc')],
  },
  {
    year: t('resume.education.english_cert_period'),
    title: t('resume.education.english_cert'),
    company: t('resume.education.english_cert_school'),
    description: [t('resume.education.english_cert_desc')],
  },
  {
    year: t('resume.education.video_cert_period'),
    title: t('resume.education.video_cert'),
    company: t('resume.education.video_cert_school'),
    description: [t('resume.education.video_cert_desc')],
  },
  {
    year: t('resume.education.highschool_period'),
    title: t('resume.education.highschool'),
    company: t('resume.education.highschool_school'),
    companyUrl: 'https://szent-erzsebet.hu/',
    description: [t('resume.education.highschool_desc')],
  },
];

// ── Stack Data ─────────────────────────────────────────
const stackCategories = [
  {
    label: 'Backend & APIs',
    items: ['Java', 'Spring Boot', 'Node.js', 'Express', 'REST APIs', 'C# ASP.NET', 'WebSocket', 'WebRTC'],
  },
  {
    label: 'Frontend & UI',
    items: ['React', 'Angular', 'JavaScript', 'TypeScript', 'TailwindCSS', 'HTML', 'CSS'],
  },
  {
    label: 'Data & Storage',
    items: ['PostgreSQL', 'PostGIS', 'MySQL', 'SQLite', 'Room ORM'],
  },
  {
    label: 'Platform & Delivery',
    items: ['Docker', 'GitHub Actions', 'Linux', 'Cloudflare', 'Nginx'],
  },
  {
    label: 'Additional Languages',
    items: ['Python', 'Go'],
  },
  {
    label: t('resume.skills.softSkills'),
    items: allTranslations[typedLang]?.resume?.skills?.softSkillItems
      ?? allTranslations['en'].resume.skills.softSkillItems,
  },
  {
    label: 'Mobile',
    items: ['Android', 'Kotlin'],
  },
  {
    label: 'Spoken Languages',
    items: ['English (C1)', 'Italian (A1)', 'Hungarian (Native)'],
  },
];

// ── Project Data ───────────────────────────────────────
const projectItems = projects
  .filter((p: any) => p.status !== 'past')
  .map((p: any) => ({
    id: p.id,
    title: p.titleKey ? t(p.titleKey) : (p.title || p.id),
    category: p.categoryKey ? t(p.categoryKey) : 'Project',
    description: p.descriptionKey ? t(p.descriptionKey) : (p.description || ''),
    url: p.url ? (p.url.startsWith('/') ? translatePath(p.url) : p.url) : '',
    links: p.links || undefined,
    status: p.status as 'active' | 'coming-soon' | 'past',
  }));

// ── Footer Data ────────────────────────────────────────
const footerNavigation = [
  { label: t('nav.home'), href: translatePath('/') },
  { label: t('nav.stories'), href: 'https://map.ballabotond.com', external: true },
  { label: t('nav.movies'), href: translatePath('/movies/') },
  { label: 'Gusto', href: 'https://gusto.ballabotond.com', external: true },
  { label: 'CV', href: 'https://cv.ballabotond.com', external: true },
];

const footerSocials = SOCIAL_LINKS.map(link => ({
  id: link.id,
  label: t(link.i18nKey),
  href: link.href,
}));
---

<PortfolioLayout
  title={t('home.title')}
  description={t('home.description')}
  keywords={t('home.keywords')}
  canonical={canonicalUrl}
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <Intro name={t('common.name')} subtitle={t('portfolio.heroSubtitle')} />

  <Nav
    homeHref={translatePath('/')}
    sections={navSections}
    cvHref="https://cv.ballabotond.com"
    languages={Object.entries(languages).map(([code, label]) => ({
      code: code.toUpperCase(),
      label: label as string,
      href: `/${code}/`,
      active: code === lang,
    }))}
  />

  <ScrollRail sections={navSections} />

  <main style="overflow-x: clip;">
    <!-- 01 · The opening -->
    <div id="manifesto">
      <Hero
        name={t('common.name')}
        tagline={t('portfolio.heroTagline')}
        subtitle={t('portfolio.heroSubtitle')}
        description={t('portfolio.heroDescription2')}
        profileImage={optimizedProfile.src}
        profileAlt={t('common.name')}
        profileLink="https://map.ballabotond.com"
      />
    </div>

    <!-- 02 · My Story -->
    <div id="story">
      <Story
        index="01"
        sectionTitle={t('resume.lifeStory.title')}
        paragraphs={lifeStoryParagraphs}
        profileImage={optimizedStoryPortrait.src}
        profileAlt={t('resume.lifeStory.caption')}
        caption={t('resume.lifeStory.caption')}
        readMoreLabel={t('common.readMore')}
        showLessLabel={t('common.showLess')}
        pullQuote1={t('resume.lifeStory.pullQuote1')}
        pullQuote2={t('resume.lifeStory.pullQuote2')}
      />
    </div>

    <!-- 03 · Resume -->
    <div id="resume">
      <Resume
        index="02"
        sectionTitle={t('resume.subtitle')}
        experienceEntries={experienceEntries}
        educationTitle={t('resume.education.title')}
        educationEntries={educationEntries}
        stackTitle={t('nav.stack')}
        categories={stackCategories}
      />
    </div>

    <!-- 04 · Projects -->
    <div id="projects">
      <Projects
        index="03"
        sectionTitle={t('projects.subtitle')}
        projects={projectItems}
        openLabel={t('projects.openProject')}
        statusLabels={{
          live: t('projects.status.live'),
          soon: t('projects.status.soon'),
          archived: t('projects.status.archived'),
        }}
      />
    </div>
  </main>

  <!-- 05 · Contact / colophon -->
  <div id="contact">
    <Footer
      index="04"
      contactLabel={t('portfolio.contact')}
      name={t('common.name')}
      role={t('portfolio.heroSubtitle')}
      email="contact@ballabotond.com"
      navigation={footerNavigation}
      navigateTitle={t('footer.navigate')}
      socials={footerSocials}
      quote={t('footer.quote.text')}
      quoteAuthor={t('footer.quote.author')}
      copyright={t('footer.copyright')}
      connectTitle={t('footer.connect')}
    />
  </div>
</PortfolioLayout>
