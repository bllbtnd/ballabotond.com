---
import PortfolioLayout from '../../layouts/PortfolioLayout.astro';
import { useTranslations, useTranslatedPath, languages, type Languages } from '../../i18n/utils';
import moviesData from '../../data/movies.json';

export function getStaticPaths() {
  return Object.keys(languages).map(lang => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;
const typedLang = lang as Languages;
const t = useTranslations(typedLang);
const translatePath = useTranslatedPath(typedLang);

const allMovies = moviesData.map((movie) => ({
  ...movie,
  rating: movie.rating ? Math.round(movie.rating * 2) / 2 : 0
}));

const ratedMovies = allMovies.filter((movie) => movie.rating > 0);
const avgRating = ratedMovies.length
  ? (ratedMovies.reduce((sum, movie) => sum + movie.rating, 0) / ratedMovies.length).toFixed(1)
  : '0.0';
const topRatedCount = ratedMovies.filter((movie) => movie.rating >= 8.5).length;
---

<PortfolioLayout
  title="Movie Ratings - Balla Botond"
  description="My personal movie ratings and reviews"
  keywords="movies, ratings, reviews, cinema"
>
  <main class="min-h-screen px-4 sm:px-6 pb-16 md:pb-20">
    <div class="max-w-6xl mx-auto pt-10 md:pt-14">
      <nav class="mb-10 md:mb-14 flex items-center justify-between border-b border-pf-border pb-4">
        <a href={translatePath('/')} class="pf-grotesk text-fluid-sm font-medium text-pf-text hover:text-pf-accent transition-colors duration-300">
          Balla Botond
        </a>
        <div class="flex items-center gap-5 md:gap-8">
          <a href="https://map.ballabotond.com" class="pf-grotesk text-fluid-xs uppercase tracking-[0.2em] text-pf-muted hover:text-pf-text transition-colors duration-300">
            {t('nav.stories')}
          </a>
          <a href={translatePath('/')} class="pf-grotesk text-fluid-xs uppercase tracking-[0.2em] text-pf-muted hover:text-pf-text transition-colors duration-300">
            {t('nav.home')}
          </a>
        </div>
      </nav>

      <header class="mb-8 md:mb-10">
        <p class="pf-grotesk text-fluid-xs uppercase tracking-[0.3em] text-pf-accent mb-4">Cinema</p>
        <h1 class="pf-serif text-pf-text leading-tight-display tracking-brutal" style="font-size: clamp(2.4rem, 1.4rem + 4.8vw, 6rem);">
          {t('movies.title')}
        </h1>
        <p class="pf-grotesk text-fluid-base text-pf-muted mt-4 max-w-2xl">
          {t('movies.description')}
        </p>
      </header>

      <section class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-8 md:mb-10">
        <article class="rounded-xl border border-pf-border bg-pf-surface px-4 py-4 md:px-5">
          <p class="pf-grotesk text-fluid-xs uppercase tracking-[0.2em] text-pf-muted">Total</p>
          <p class="pf-serif text-fluid-xl text-pf-text mt-2">{allMovies.length}</p>
        </article>
        <article class="rounded-xl border border-pf-border bg-pf-surface px-4 py-4 md:px-5">
          <p class="pf-grotesk text-fluid-xs uppercase tracking-[0.2em] text-pf-muted">Average</p>
          <p class="pf-serif text-fluid-xl text-pf-text mt-2">{avgRating}</p>
        </article>
        <article class="rounded-xl border border-pf-border bg-pf-surface px-4 py-4 md:px-5">
          <p class="pf-grotesk text-fluid-xs uppercase tracking-[0.2em] text-pf-muted">8.5+ Rated</p>
          <p class="pf-serif text-fluid-xl text-pf-text mt-2">{topRatedCount}</p>
        </article>
      </section>

      <section class="rounded-2xl border border-pf-border bg-pf-surface p-4 sm:p-5 md:p-6 mb-8 md:mb-10">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
          <label class="block">
            <span class="block pf-grotesk text-fluid-xs uppercase tracking-[0.2em] text-pf-muted mb-2">{t('portfolio.filterByRating')}</span>
            <select id="rating-filter-select" class="w-full bg-pf-bg border border-pf-border rounded-lg px-3 py-2.5 text-pf-text pf-grotesk text-fluid-sm focus:outline-none focus:border-pf-accent transition-colors">
              <option value="all">{t('portfolio.allMovies')}</option>
              <option value="wtw">{t('portfolio.wantToWatch')}</option>
              <option value="good">{t('portfolio.good')}</option>
              <option value="medium">{t('portfolio.medium')}</option>
              <option value="bad">{t('portfolio.bad')}</option>
            </select>
          </label>

          <label class="block">
            <span class="block pf-grotesk text-fluid-xs uppercase tracking-[0.2em] text-pf-muted mb-2">{t('portfolio.sortBy')}</span>
            <select id="sort-select" class="w-full bg-pf-bg border border-pf-border rounded-lg px-3 py-2.5 text-pf-text pf-grotesk text-fluid-sm focus:outline-none focus:border-pf-accent transition-colors">
              <option value="rating-desc">{t('portfolio.highestRated')}</option>
              <option value="rating-asc">{t('portfolio.lowestRated')}</option>
              <option value="title-asc">{t('portfolio.titleAZ')}</option>
              <option value="title-desc">{t('portfolio.titleZA')}</option>
            </select>
          </label>

          <label class="block">
            <span class="block pf-grotesk text-fluid-xs uppercase tracking-[0.2em] text-pf-muted mb-2">{t('portfolio.perPage')}</span>
            <select id="per-page-select" class="w-full bg-pf-bg border border-pf-border rounded-lg px-3 py-2.5 text-pf-text pf-grotesk text-fluid-sm focus:outline-none focus:border-pf-accent transition-colors">
              <option value="18">18</option>
              <option value="36">36</option>
              <option value="72">72</option>
            </select>
          </label>

          <label class="block">
            <span class="block pf-grotesk text-fluid-xs uppercase tracking-[0.2em] text-pf-muted mb-2">Search</span>
            <input
              id="search-input"
              type="text"
              placeholder={t('portfolio.searchMovies')}
              class="w-full bg-pf-bg border border-pf-border rounded-lg px-3 py-2.5 text-pf-text pf-grotesk text-fluid-sm placeholder:text-pf-muted focus:outline-none focus:border-pf-accent transition-colors"
            />
          </label>
        </div>
      </section>

      <section id="movies-container" class="space-y-3 md:space-y-4" aria-live="polite"></section>

      <section id="pagination" class="mt-8 md:mt-10 flex flex-wrap items-center justify-center gap-2"></section>
    </div>
  </main>
</PortfolioLayout>

<script define:vars={{ allMovies, labels: {
  noMoviesFound: t('portfolio.noMoviesFound'),
  prev: t('portfolio.prev'),
  next: t('portfolio.next'),
  wantToWatch: t('portfolio.wantToWatch')
} }}>
  const container = document.getElementById('movies-container');
  const pagination = document.getElementById('pagination');
  const ratingFilter = document.getElementById('rating-filter-select');
  const sortSelect = document.getElementById('sort-select');
  const perPageSelect = document.getElementById('per-page-select');
  const searchInput = document.getElementById('search-input');

  let currentPage = 1;
  let filtered = [...allMovies];

  function ratingGroup(rating) {
    if (!rating || rating === 0) return 'wtw';
    if (rating >= 7) return 'good';
    if (rating >= 5) return 'medium';
    return 'bad';
  }

  function sortMovies(list, sortType) {
    return [...list].sort((a, b) => {
      if (sortType === 'rating-desc') return b.rating - a.rating;
      if (sortType === 'rating-asc') return a.rating - b.rating;
      if (sortType === 'title-desc') return b.title.localeCompare(a.title);
      return a.title.localeCompare(b.title);
    });
  }

  function ratingPills(rating) {
    if (!rating || rating === 0) {
      return '<span class="inline-flex items-center rounded-full border border-pf-border px-3 py-1 pf-grotesk text-fluid-xs uppercase tracking-[0.14em] text-pf-accent">' + labels.wantToWatch + '</span>';
    }
    const width = Math.max(0, Math.min(100, (rating / 10) * 100));
    return (
      '<div class="flex items-center gap-3">' +
        '<div class="w-24 h-2 rounded-full bg-pf-border overflow-hidden">' +
          '<div class="h-2 bg-pf-accent" style="width:' + width + '%"></div>' +
        '</div>' +
        '<span class="pf-grotesk text-fluid-sm text-pf-accent font-medium">' + rating.toFixed(1) + '</span>' +
      '</div>'
    );
  }

  function renderMovies() {
    if (!container || !pagination || !perPageSelect) return;

    const perPage = Number(perPageSelect.value);
    const pageCount = Math.max(1, Math.ceil(filtered.length / perPage));
    if (currentPage > pageCount) currentPage = pageCount;

    const start = (currentPage - 1) * perPage;
    const items = filtered.slice(start, start + perPage);

    if (!items.length) {
      container.innerHTML = `
        <div class="rounded-2xl border border-pf-border bg-pf-surface px-6 py-12 text-center">
          <p class="pf-grotesk text-fluid-base text-pf-muted">${labels.noMoviesFound}</p>
        </div>
      `;
    } else {
      container.innerHTML = items.map((movie) => `
        <article class="rounded-2xl border border-pf-border bg-pf-surface px-4 sm:px-5 md:px-6 py-4 md:py-5 hover:border-pf-accent/50 transition-colors duration-300">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <h2 class="pf-serif text-fluid-lg text-pf-text leading-tight">${movie.title}</h2>
            ${ratingPills(movie.rating)}
          </div>
        </article>
      `).join('');
    }

    renderPagination(pageCount);
  }

  function renderPagination(pageCount) {
    if (!pagination) return;

    if (pageCount <= 1) {
      pagination.innerHTML = '';
      return;
    }

    const pages = [];
    for (let page = 1; page <= pageCount; page += 1) {
      if (
        page === 1 ||
        page === pageCount ||
        Math.abs(page - currentPage) <= 1
      ) {
        pages.push(page);
      }
    }

    const compact = pages.filter((value, index) => index === 0 || value !== pages[index - 1] + 1 ? true : true);

    let pageButtons = '';
    compact.forEach((value, index) => {
      if (index > 0 && value - compact[index - 1] > 1) {
        pageButtons += '<span class="px-2 text-pf-muted">…</span>';
      }
      pageButtons += `
        <button class="page-btn ${value === currentPage ? 'active' : ''}" data-page="${value}">${value}</button>
      `;
    });

    pagination.innerHTML = `
      <button class="page-btn" data-page="${currentPage - 1}" ${currentPage === 1 ? 'disabled' : ''}>${labels.prev}</button>
      ${pageButtons}
      <button class="page-btn" data-page="${currentPage + 1}" ${currentPage === pageCount ? 'disabled' : ''}>${labels.next}</button>
    `;

    pagination.querySelectorAll('button[data-page]').forEach((button) => {
      button.addEventListener('click', () => {
        const nextPage = Number(button.getAttribute('data-page'));
        if (!Number.isNaN(nextPage)) {
          currentPage = nextPage;
          renderMovies();
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });
    });
  }

  function applyFilters() {
    if (!ratingFilter || !sortSelect || !searchInput) return;

    const selectedRating = ratingFilter.value;
    const selectedSort = sortSelect.value;
    const query = searchInput.value.trim().toLowerCase();

    filtered = allMovies.filter((movie) => {
      const matchesRating = selectedRating === 'all' || ratingGroup(movie.rating) === selectedRating;
      const matchesQuery = !query || movie.title.toLowerCase().includes(query);
      return matchesRating && matchesQuery;
    });

    filtered = sortMovies(filtered, selectedSort);
    currentPage = 1;
    renderMovies();
  }

  [ratingFilter, sortSelect, perPageSelect].forEach((control) => {
    if (control) control.addEventListener('change', applyFilters);
  });

  if (searchInput) {
    searchInput.addEventListener('input', applyFilters);
  }

  applyFilters();
</script>

<style is:global>
  .page-btn {
    @apply inline-flex items-center justify-center min-h-11 px-3 py-2 rounded-lg border border-pf-border text-pf-muted bg-pf-bg hover:text-pf-accent hover:border-pf-accent transition-colors duration-200 disabled:opacity-40 disabled:cursor-not-allowed;
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: clamp(0.82rem, 0.8rem + 0.15vw, 0.95rem);
  }

  .page-btn.active {
    @apply border-pf-accent text-pf-accent bg-pf-surface;
  }
</style>