---
// 404 page for Balla Botond's Astro site
import PortfolioLayout from '../layouts/PortfolioLayout.astro';
import { defaultLang, useTranslations } from '../i18n/utils';

const t = useTranslations(defaultLang);
---

<PortfolioLayout title={`${t('notFound.title')} | ${t('common.name')}`}>

  <main class="relative min-h-[100svh] flex items-center justify-center overflow-hidden">

    {/* Background typographic layer — large faded 404 */}
    <div
      class="absolute inset-0 flex items-center justify-center pointer-events-none select-none"
      aria-hidden="true"
    >
      <span
        class="pf-serif text-pf-border whitespace-nowrap"
        style="font-size: clamp(10rem, 5rem + 30vw, 40rem); line-height: 0.85; letter-spacing: -0.04em; opacity: 1;"
      >
        {t('notFound.heading')}
      </span>
    </div>

    {/* Accent line — decorative */}
    <div class="absolute top-1/2 left-0 w-full pointer-events-none" aria-hidden="true">
      <div class="h-px bg-pf-border w-full"></div>
    </div>

    {/* Foreground content */}
    <div class="relative z-10 w-full max-w-[90vw] px-6 md:px-12 text-center">
      <p class="pf-grotesk text-fluid-sm uppercase tracking-[0.3em] text-pf-accent mb-6 md:mb-8">
        {t('notFound.subtitle')}
      </p>

      <h1
        class="pf-serif text-pf-text leading-tight-display tracking-brutal mb-8"
        style="font-size: clamp(2.5rem, 1.5rem + 5vw, 7rem);"
      >
        {t('notFound.title')}
      </h1>

      <p class="pf-grotesk text-fluid-base text-pf-muted leading-relaxed max-w-xl mx-auto mb-12">
        {t('notFound.description')}
      </p>

      {/* Action buttons */}
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-10">
        <a
          href="/"
          class="pf-grotesk text-fluid-sm uppercase tracking-[0.2em] text-pf-text border-b border-pf-text pb-1 hover:text-pf-accent hover:border-pf-accent transition-colors duration-300"
        >
          {t('notFound.goHome')}
        </a>
      </div>
    </div>

    {/* Scroll indicator aesthetic — bottom left */}
    <div class="absolute bottom-8 left-6 md:left-12 flex items-center gap-3">
      <div class="w-px h-12 bg-pf-muted origin-top"></div>
      <span class="pf-grotesk text-fluid-xs uppercase tracking-[0.2em] text-pf-muted">404</span>
    </div>

  </main>

</PortfolioLayout>
