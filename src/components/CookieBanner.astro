---
/**
 * CookieBanner.astro — minimal GDPR consent pill.
 */
---

<div
  id="cookie-banner"
  role="dialog"
  aria-modal="false"
  aria-label="Cookie consent"
>
  <span id="cookie-text">This site uses analytics cookies.</span>
  <div id="cookie-actions">
    <button id="cookie-decline" type="button">Decline</button>
    <button id="cookie-accept" type="button">Accept</button>
  </div>
</div>

<style>
  #cookie-banner {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(calc(100% + 2.5rem));
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.65rem 0.75rem 0.65rem 1.25rem;
    border-radius: 999px;
    background: rgba(26, 26, 26, 0.88);
    backdrop-filter: blur(48px) saturate(1.8);
    -webkit-backdrop-filter: blur(48px) saturate(1.8);
    border: 0.5px solid rgba(255, 255, 255, 0.09);
    box-shadow: 0 8px 32px rgba(26, 26, 26, 0.14), inset 0 0.5px 0 rgba(255, 255, 255, 0.07);
    white-space: nowrap;
    visibility: hidden;
    transition-property: transform, visibility;
    transition-duration: 0.5s, 0s;
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1), linear;
    transition-delay: 0s, 0.5s;
  }

  #cookie-banner.visible {
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    transition-property: transform, visibility;
    transition-duration: 0.5s, 0s;
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1), linear;
    transition-delay: 0s, 0s;
  }

  #cookie-banner.hiding {
    transform: translateX(-50%) translateY(calc(100% + 2.5rem));
    visibility: hidden;
    transition-property: transform, visibility;
    transition-duration: 0.45s, 0s;
    transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1), linear;
    transition-delay: 0s, 0.45s;
  }

  #cookie-text {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: clamp(0.7rem, 0.65rem + 0.25vw, 0.8rem);
    letter-spacing: 0.04em;
    color: #B8B2A8;
  }

  #cookie-actions {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  #cookie-decline,
  #cookie-accept {
    font-family: 'Space Grotesk', system-ui, sans-serif;
    font-size: clamp(0.65rem, 0.6rem + 0.2vw, 0.75rem);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    cursor: pointer;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    transition: background 0.2s ease, color 0.2s ease;
    white-space: nowrap;
  }

  #cookie-decline {
    background: transparent;
    color: #7A7570;
  }

  #cookie-decline:hover {
    color: #B8B2A8;
  }

  #cookie-accept {
    background: #7A6C5D;
    color: #F0EBE3;
  }

  #cookie-accept:hover {
    background: #9B8E7E;
  }

  /* Mobile: wrap to two lines if viewport too narrow */
  @media (max-width: 420px) {
    #cookie-banner {
      white-space: normal;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
      border-radius: 1.25rem;
      padding: 1rem 1.25rem;
      width: calc(100% - 2rem);
      bottom: 1rem;
    }
    #cookie-actions {
      width: 100%;
      justify-content: flex-end;
    }
  }
</style>

<script>
  const STORAGE_KEY = 'cookie_consent';

  function grantConsent() {
    const _gtag = (window as any).gtag;
    if (typeof _gtag === 'function') {
      _gtag('consent', 'update', { analytics_storage: 'granted' });
    }
  }

  function hideBanner(banner: HTMLElement) {
    banner.classList.remove('visible');
    banner.classList.add('hiding');
    setTimeout(() => banner.classList.remove('hiding'), 500);
  }

  function showBanner(banner: HTMLElement) {
    banner.classList.add('visible');
  }

  function init() {
    console.log('[CookieBanner] init() called');
    const banner = document.getElementById('cookie-banner') as HTMLElement | null;
    if (!banner) {
      console.warn('[CookieBanner] #cookie-banner element not found in DOM');
      return;
    }
    console.log('[CookieBanner] banner element found');

    const stored = localStorage.getItem(STORAGE_KEY);
    console.log('[CookieBanner] stored consent:', stored);

    if (stored === 'accepted') {
      console.log('[CookieBanner] already accepted, granting consent silently');
      grantConsent();
      return;
    }
    if (stored === 'declined') {
      console.log('[CookieBanner] already declined, hiding banner');
      return;
    }

    console.log('[CookieBanner] first visit — will show in 1.2s');
    setTimeout(() => {
      console.log('[CookieBanner] showing banner now');
      showBanner(banner);
    }, 1200);

    // Attach listeners only once
    const acceptBtn = document.getElementById('cookie-accept');
    const declineBtn = document.getElementById('cookie-decline');

    acceptBtn?.addEventListener('click', () => {
      localStorage.setItem(STORAGE_KEY, 'accepted');
      grantConsent();
      hideBanner(banner);
    }, { once: true });

    declineBtn?.addEventListener('click', () => {
      localStorage.setItem(STORAGE_KEY, 'declined');
      hideBanner(banner);
    }, { once: true });
  }

  // Run on initial load and Astro page transitions
  init();
  document.addEventListener('astro:after-swap', init);
</script>
