---
/**
 * Resume.astro — timeline + stack specimen sheet.
 * Experience & education: vertical timeline with branching connector dots,
 * card panels with arrow pointers, and a pulsing dot for current roles.
 * Stack: unchanged specimen grid.
 */
import SectionHead from './SectionHead.astro';

interface TimelineEntry {
  year: string;
  title: string;
  company: string;
  companyUrl?: string;
  description: string[];
  isCurrent?: boolean;
}

interface StackCategory {
  label: string;
  items: string[];
}

interface Props {
  index: string;
  sectionTitle: string;
  experienceEntries: TimelineEntry[];
  educationTitle: string;
  educationEntries: TimelineEntry[];
  stackTitle: string;
  categories: StackCategory[];
}

const {
  index,
  sectionTitle,
  experienceEntries,
  educationTitle,
  educationEntries,
  stackTitle,
  categories,
} = Astro.props;
---

<section class="pf-section" aria-label={sectionTitle}>
  <div class="pf-section-inner">
    <SectionHead index={index} label={sectionTitle} title={sectionTitle} />

    <!-- Experience timeline -->
    <div class="pf-timeline-block" data-reveal>
      <div class="pf-timeline-line" aria-hidden="true"></div>

      {experienceEntries.map((entry, i) => (
        <article class="pf-tl-entry" style={`--reveal-delay:${i * 80}ms`} data-reveal>
          <div class="pf-tl-dot-col" aria-hidden="true">
            <span class:list={['pf-tl-dot', { 'pf-tl-dot--current': entry.isCurrent }]}></span>
          </div>
          <div class="pf-tl-card">
            <div class="pf-tl-meta pf-grotesk">
              <span class="pf-tl-year">{entry.year}</span>

            </div>
            <h4 class="pf-tl-title pf-serif">{entry.title}</h4>
            {entry.companyUrl ? (
              <a href={entry.companyUrl} target="_blank" rel="noopener noreferrer" class="pf-tl-company pf-grotesk pf-link">
                {entry.company}
              </a>
            ) : (
              <span class="pf-tl-company pf-grotesk">{entry.company}</span>
            )}
            {entry.description.length > 0 && (
              <ul class="pf-tl-desc-list pf-grotesk">
                {entry.description.map((desc) => (
                  <li>{desc}</li>
                ))}
              </ul>
            )}
          </div>
        </article>
      ))}
    </div>

    <!-- Education timeline -->
    <div class="pf-timeline-block pf-timeline-block--edu">
      <h3 class="pf-tl-section-label pf-grotesk" data-reveal>{educationTitle}</h3>
      <div class="pf-timeline-line" aria-hidden="true"></div>

      {educationEntries.map((entry, i) => (
        <article class="pf-tl-entry pf-tl-entry--compact" style={`--reveal-delay:${i * 60}ms`} data-reveal>
          <div class="pf-tl-dot-col" aria-hidden="true">
            <span class:list={['pf-tl-dot', { 'pf-tl-dot--current': entry.isCurrent }]}></span>
          </div>
          <div class="pf-tl-card">
            <div class="pf-tl-meta pf-grotesk">
              <span class="pf-tl-year">{entry.year}</span>
            </div>
            <h4 class="pf-tl-title pf-tl-title--sm pf-serif">{entry.title}</h4>
            {entry.companyUrl ? (
              <a href={entry.companyUrl} target="_blank" rel="noopener noreferrer" class="pf-tl-company pf-grotesk pf-link">
                {entry.company}
              </a>
            ) : (
              <span class="pf-tl-company pf-grotesk">{entry.company}</span>
            )}
            {entry.description.length > 0 && (
              <ul class="pf-tl-desc-list pf-grotesk">
                {entry.description.map((desc) => (
                  <li>{desc}</li>
                ))}
              </ul>
            )}
          </div>
        </article>
      ))}
    </div>

    <!-- Stack specimen sheet -->
    <div class="pf-stack">
      <h3 class="pf-stack-title pf-grotesk" data-reveal>{stackTitle}</h3>
      <div class="pf-stack-grid">
        {categories.map((cat, i) => (
          <div class="pf-stack-cat" data-reveal style={`--reveal-delay:${Math.min(i % 4, 3) * 60}ms`}>
            <p class="pf-stack-label pf-grotesk">{cat.label}</p>
            <ul class="pf-stack-list">
              {cat.items.map((item) => (
                <li class="pf-grotesk">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .pf-section {
    padding: clamp(5rem, 12vh, 9rem) 0;
  }
  .pf-section-inner {
    max-width: 90rem;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  /* ── Timeline block ─────────────────────────────── */
  .pf-timeline-block {
    position: relative;
    /* Space for the vertical line + dot on the left */
    padding-left: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: clamp(4rem, 8vh, 6rem);
  }
  .pf-timeline-block--edu {
    margin-top: clamp(1rem, 2vh, 2rem);
  }

  /* Vertical ink line — draws itself in on scroll reveal */
  .pf-timeline-line {
    position: absolute;
    left: calc(clamp(2.5rem, 5vw, 4rem) / 2 - 0.5px);
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--pf-border);
    transform-origin: top;
    transform: scaleY(0);
    transition: transform 1.6s var(--pf-ease) 0.15s;
  }
  .pf-timeline-block.is-in .pf-timeline-line,
  .pf-timeline-block--edu .pf-timeline-line {
    transform: scaleY(1);
  }
  :global(.no-js) .pf-timeline-line { transform: scaleY(1); }

  /* Education section label */
  .pf-tl-section-label {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pf-accent);
    margin: 0 0 clamp(1.5rem, 3vh, 2.5rem);
  }

  /* ── Entry row ──────────────────────────────────── */
  .pf-tl-entry {
    position: relative;
    margin-bottom: clamp(1.6rem, 3.5vh, 2.8rem);
  }
  .pf-tl-entry:last-child { margin-bottom: 0; }

  /* ── Dot ────────────────────────────────────────── */
  .pf-tl-dot-col {
    position: absolute;
    /* Align horizontally with the line */
    left: calc(-1 * clamp(2.5rem, 5vw, 4rem));
    width: clamp(2.5rem, 5vw, 4rem);
    top: clamp(1.4rem, 2.5vh, 2rem);
    display: flex;
    justify-content: center;
  }

  .pf-tl-dot {
    position: relative;
    display: block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--pf-bg);
    border: 2px solid var(--pf-border);
    transition: border-color 0.4s var(--pf-ease), background 0.4s var(--pf-ease);
    flex-shrink: 0;
  }
  .pf-tl-dot--current {
    background: var(--pf-accent);
    border-color: var(--pf-accent);
  }
  /* ── Card panel ─────────────────────────────────── */
  .pf-tl-card {
    padding: clamp(1.4rem, 2.5vh, 2rem) clamp(1.4rem, 2.5vw, 2rem);
    background: var(--pf-surface);
    border: 1px solid var(--pf-border);
    position: relative;
    transition: border-color 0.35s ease;
  }
  .pf-tl-card:hover {
    border-color: color-mix(in srgb, var(--pf-accent) 45%, var(--pf-border));
  }

  /* Left-pointing diamond arrow connector */
  .pf-tl-card::before {
    content: '';
    position: absolute;
    left: -7px;
    top: clamp(1.4rem, 2.5vh, 2rem);
    width: 12px;
    height: 12px;
    background: var(--pf-surface);
    border-left: 1px solid var(--pf-border);
    border-bottom: 1px solid var(--pf-border);
    transform: rotate(45deg);
    transition: border-color 0.35s ease;
  }
  .pf-tl-card:hover::before {
    border-color: color-mix(in srgb, var(--pf-accent) 45%, var(--pf-border));
  }

  /* ── Meta (year + badge) ────────────────────────── */
  .pf-tl-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
  }
  .pf-tl-year {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pf-muted);
  }

  /* ── Title ──────────────────────────────────────── */
  .pf-tl-title {
    font-size: clamp(1.5rem, 1rem + 2vw, 2.5rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--pf-text);
    margin: 0 0 0.35rem;
  }
  .pf-tl-title--sm {
    font-size: clamp(1.1rem, 0.9rem + 1vw, 1.65rem);
  }

  /* ── Company ────────────────────────────────────── */
  .pf-tl-company {
    font-size: 0.84rem;
    color: var(--pf-accent);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 0.8rem;
  }

  /* ── Description list ───────────────────────────── */
  .pf-tl-desc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--pf-border);
    padding-top: 0.85rem;
    margin-top: 0.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .pf-tl-desc-list li {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--pf-muted);
    padding-left: 1.1rem;
    position: relative;
  }
  .pf-tl-desc-list li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--pf-accent);
  }

  /* ── Stack cards ────────────────────────────────── */
  .pf-stack {
    border-top: 1px solid var(--pf-border);
    padding-top: clamp(2rem, 4vh, 3rem);
  }
  .pf-stack-title {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pf-accent);
    margin: 0 0 1.6rem;
  }
  .pf-stack-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(0.8rem, 1.5vw, 1.2rem);
  }
  @media (min-width: 900px) {
    .pf-stack-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* Card — same surface/border/hover as timeline + project cards */
  .pf-stack-cat {
    background: var(--pf-surface);
    border: 1px solid var(--pf-border);
    padding: clamp(1.1rem, 2vw, 1.6rem);
    transition: border-color 0.35s ease;
  }
  .pf-stack-cat:hover {
    border-color: color-mix(in srgb, var(--pf-accent) 45%, var(--pf-border));
  }

  .pf-stack-label {
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--pf-accent);
    margin: 0 0 0.85rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--pf-border);
  }
  .pf-stack-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .pf-stack-list li {
    font-size: 0.88rem;
    line-height: 1.85;
    color: var(--pf-text);
  }
</style>
