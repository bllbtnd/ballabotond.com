---
/**
 * Resume.astro — the curriculum as a ledger.
 * Full-width hairline rows: year / serif title / description,
 * with an accent timeline that draws itself down the margin as
 * you read (GSAP scrub). Stack closes the section as a specimen
 * sheet of four columns.
 */
import SectionHead from './SectionHead.astro';

interface TimelineEntry {
  year: string;
  title: string;
  company: string;
  companyUrl?: string;
  description: string[];
  isCurrent?: boolean;
}

interface StackCategory {
  label: string;
  items: string[];
}

interface Props {
  index: string;
  sectionTitle: string;
  experienceEntries: TimelineEntry[];
  educationTitle: string;
  educationEntries: TimelineEntry[];
  stackTitle: string;
  categories: StackCategory[];
}

const {
  index,
  sectionTitle,
  experienceEntries,
  educationTitle,
  educationEntries,
  stackTitle,
  categories,
} = Astro.props;

const groups: { title?: string; entries: TimelineEntry[]; compact?: boolean }[] = [
  { entries: experienceEntries },
  { title: educationTitle, entries: educationEntries, compact: true },
];
---

<section class="pf-section" aria-label={sectionTitle}>
  <div class="pf-section-inner">
    <SectionHead index={index} label={sectionTitle} title={sectionTitle} />

    <div class="pf-ledger-wrap" id="pf-ledger">
      {groups.map((group) => (
        <div class="pf-ledger-group">
          {group.title && (
            <h3 class="pf-ledger-group-title pf-grotesk" data-reveal>{group.title}</h3>
          )}
          {group.entries.map((entry, i) => (
            <article
              class:list={['pf-entry', { 'pf-entry-compact': group.compact }]}
              data-reveal
              style={`--reveal-delay:${Math.min(i, 4) * 50}ms`}
            >
              <div class="pf-entry-year pf-grotesk">
                {entry.year}
                {entry.isCurrent && <span class="pf-entry-now" aria-hidden="true"></span>}
              </div>
              <div class="pf-entry-main">
                <h4 class="pf-entry-title pf-serif">{entry.title}</h4>
                {entry.companyUrl ? (
                  <a href={entry.companyUrl} target="_blank" rel="noopener noreferrer" class="pf-link pf-entry-company pf-grotesk">
                    {entry.company}
                  </a>
                ) : (
                  <span class="pf-entry-company pf-grotesk">{entry.company}</span>
                )}
              </div>
              <div class="pf-entry-body">
                {entry.description.map((desc) => (
                  <p class="pf-entry-desc pf-grotesk">{desc}</p>
                ))}
              </div>
            </article>
          ))}
        </div>
      ))}
    </div>

    <!-- Stack specimen sheet -->
    <div class="pf-stack">
      <h3 class="pf-ledger-group-title pf-grotesk" data-reveal>{stackTitle}</h3>
      <div class="pf-stack-grid">
        {categories.map((cat, i) => (
          <div class="pf-stack-cat" data-reveal style={`--reveal-delay:${Math.min(i % 4, 3) * 60}ms`}>
            <p class="pf-stack-label pf-grotesk">{cat.label}</p>
            <ul class="pf-stack-list">
              {cat.items.map((item) => (
                <li class="pf-grotesk">{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .pf-section {
    padding: clamp(5rem, 12vh, 9rem) 0;
  }
  .pf-section-inner {
    max-width: 90rem;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  /* Ledger */
  .pf-ledger-wrap {
    position: relative;
  }
  @media (min-width: 900px) {
    .pf-ledger-wrap { padding-left: clamp(1.6rem, 3vw, 3rem); }
  }

  .pf-ledger-group + .pf-ledger-group { margin-top: clamp(3rem, 6vh, 4.5rem); }

  .pf-ledger-group-title {
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--pf-accent);
    margin: 0 0 1.6rem;
  }

  .pf-entry {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.5rem;
    padding: clamp(1.4rem, 2.6vw, 2.2rem) 0;
    border-top: 1px solid var(--pf-border);
  }
  @media (min-width: 900px) {
    .pf-entry {
      grid-template-columns: 9rem 1.1fr 1fr;
      gap: clamp(1.5rem, 3vw, 3rem);
      align-items: start;
    }
  }

  .pf-entry-year {
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pf-muted);
    padding-top: 0.55rem;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }
  .pf-entry-now {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--pf-accent);
    flex-shrink: 0;
    align-self: center;
  }

  .pf-entry-title {
    font-size: clamp(1.7rem, 1.2rem + 2.2vw, 2.8rem);
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--pf-text);
    margin: 0 0 0.45rem;
  }
  .pf-entry-compact .pf-entry-title {
    font-size: clamp(1.25rem, 1rem + 1vw, 1.7rem);
  }
  .pf-entry-company {
    font-size: 0.88rem;
    color: var(--pf-accent);
    text-decoration: none;
  }
  span.pf-entry-company { display: inline-block; }

  .pf-entry-desc {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--pf-muted);
    margin: 0 0 0.5rem;
  }
  .pf-entry-desc:last-child { margin-bottom: 0; }

  /* Stack specimen sheet */
  .pf-stack {
    margin-top: clamp(3.5rem, 8vh, 6rem);
    border-top: 1px solid var(--pf-border);
    padding-top: clamp(2rem, 4vh, 3rem);
  }
  .pf-stack-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.2rem 2rem;
  }
  @media (min-width: 900px) {
    .pf-stack-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .pf-stack-label {
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pf-muted);
    margin: 0 0 0.8rem;
    padding-bottom: 0.55rem;
    border-bottom: 1px solid var(--pf-border);
  }
  .pf-stack-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .pf-stack-list li {
    font-size: 0.92rem;
    line-height: 1.9;
    color: var(--pf-text);
  }
</style>
