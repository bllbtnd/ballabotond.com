---
/**
 * Story.astro — the narrative as an editorial spread.
 * Opening paragraph set as an oversized serif lead with a drop cap,
 * then a sticky parallax portrait beside the remaining chapters.
 * Mobile: lead always visible, the rest behind a Read more toggle.
 */
import SectionHead from './SectionHead.astro';

interface Props {
  index: string;
  sectionTitle: string;
  paragraphs: string[];
  profileImage: string;
  profileAlt: string;
  caption?: string;
  readMoreLabel: string;
  showLessLabel: string;
}

const {
  index,
  sectionTitle,
  paragraphs,
  profileImage,
  profileAlt,
  caption,
  readMoreLabel,
  showLessLabel,
} = Astro.props;

const [lead, ...rest] = paragraphs;
---

<section class="pf-section" aria-label={sectionTitle}>
  <div class="pf-section-inner">
    <SectionHead index={index} label={sectionTitle} title={sectionTitle} />

    {lead && (
      <p class="pf-story-lead pf-serif" data-reveal>{lead}</p>
    )}

    <div class="pf-story-grid" id="pf-story-text" data-collapsed="true">
      <div class="pf-story-portrait-col">
        <figure class="pf-story-portrait" data-reveal>
          <div class="pf-story-frame">
            <img
              src={profileImage}
              alt={profileAlt}
              width="600"
              height="590"
              loading="lazy"
              decoding="async"
              data-px="-0.06"
              data-px-scale="1.14"
            />
          </div>
          {caption && <figcaption class="pf-grotesk">{caption}</figcaption>}
        </figure>
      </div>

      <div class="pf-story-text">
        {rest.map((text, i) => (
          <p
            class="pf-grotesk pf-story-extra"
            data-reveal
            style={`--reveal-delay:${Math.min(i, 4) * 60}ms`}
          >
            {text}
          </p>
        ))}

        <button type="button" class="pf-story-toggle pf-grotesk" id="pf-story-toggle" aria-expanded="false" aria-controls="pf-story-text">
          <span data-more>{readMoreLabel}</span>
          <span data-less hidden>{showLessLabel}</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .pf-section {
    padding: clamp(5rem, 12vh, 9rem) 0;
  }
  .pf-section-inner {
    max-width: 90rem;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  /* Oversized opening — the first chapter as a pull statement */
  .pf-story-lead {
    margin: 0 0 clamp(3rem, 7vh, 5rem);
    max-width: 56rem;
    font-size: clamp(1.35rem, 1rem + 1.8vw, 2.3rem);
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--pf-text);
  }
  .pf-story-lead::first-letter {
    font-size: 3.2em;
    line-height: 0.75;
    float: left;
    padding: 0.08em 0.14em 0 0;
    color: var(--pf-accent);
  }

  .pf-story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 1024px) {
    .pf-story-grid {
      grid-template-columns: 1fr 1.4fr;
      gap: clamp(3rem, 6vw, 6rem);
    }
  }

  .pf-story-portrait-col { position: relative; }
  .pf-story-portrait {
    margin: 0;
    position: sticky;
    top: clamp(7.5rem, 10vh, 8.5rem);
  }
  .pf-story-frame {
    overflow: hidden;
    clip-path: inset(100% 0 0 0);
    transition: clip-path 1.1s var(--pf-ease) 0.1s;
  }
  .pf-story-portrait.is-in .pf-story-frame,
  :global(.no-js) .pf-story-frame {
    clip-path: inset(0 0 0 0);
  }
  @media (prefers-reduced-motion: reduce) {
    .pf-story-frame { clip-path: none; transition: none; }
  }
  .pf-story-frame img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1;
    object-fit: cover;
    filter: saturate(0.9);
    transform: scale(1.14);
    will-change: transform;
  }
  .pf-story-portrait figcaption {
    margin-top: 0.9rem;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pf-muted);
  }

  .pf-story-text p {
    margin: 0 0 1.6rem;
    font-size: clamp(1rem, 0.92rem + 0.4vw, 1.15rem);
    line-height: 1.75;
    color: var(--pf-text);
  }
  .pf-story-text p + p {
    text-indent: 2em;
  }

  /* Read more toggle — visible only below lg */
  .pf-story-toggle {
    display: none;
    align-items: center;
    gap: 0.55rem;
    margin-top: 0.4rem;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--pf-accent);
  }
  .pf-story-toggle svg { transition: transform 0.3s var(--pf-ease); }

  @media (max-width: 1023px) {
    .pf-story-toggle { display: inline-flex; }
    .pf-story-grid[data-collapsed="true"] .pf-story-extra { display: none; }
    .pf-story-grid[data-collapsed="false"] .pf-story-toggle svg { transform: rotate(180deg); }
    .pf-story-portrait { position: static; }
  }
</style>

<script>
  function initStoryToggle() {
    const text = document.getElementById('pf-story-text');
    const toggle = document.getElementById('pf-story-toggle');
    if (!text || !toggle) return;

    toggle.addEventListener('click', () => {
      const collapsed = text.dataset.collapsed === 'true';
      text.dataset.collapsed = String(!collapsed);
      toggle.setAttribute('aria-expanded', String(collapsed));
      toggle.querySelector('[data-more]')?.toggleAttribute('hidden', collapsed);
      toggle.querySelector('[data-less]')?.toggleAttribute('hidden', !collapsed);
      if (!collapsed) text.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  }

  initStoryToggle();
  document.addEventListener('astro:after-swap', initStoryToggle);
</script>
