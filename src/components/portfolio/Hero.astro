---
/**
 * Hero.astro — the portrait-led opening.
 */
interface Props {
  name: string;
  tagline: string;
  subtitle: string;
  description: string;
  locations?: string;
  profileImage: string;
  profileAlt?: string;
  profileLink?: string;
}

const {
  name,
  tagline,
  subtitle,
  description,
  locations = 'Budapest · Esztergom · Pécs',
  profileImage,
  profileAlt = '',
  profileLink,
} = Astro.props;

const taglineLine = tagline.split('\n').join(' ');
---

<section class="pf-hero" aria-label="Introduction" id="pf-hero">
  <!-- Giant watermark — slower than the page, leans toward the cursor -->
  <div class="pf-hero-watermark" data-px="0.3" aria-hidden="true">
    <span class="pf-serif" id="pf-hero-wm">{name}</span>
  </div>

  <div class="pf-hero-stage">
    <!-- Kicker -->
    <div class="pf-hero-kicker pf-hero-fadein">
      <span class="pf-hero-rule" aria-hidden="true"></span>
      <span class="pf-grotesk">{subtitle}</span>
      <span class="pf-hero-rule" aria-hidden="true"></span>
    </div>

    <!-- Center: portrait panel with the name below it -->
    <div class="pf-hero-center">
      <div class="pf-hero-media-wrap">
        <div class="pf-hero-media" id="pf-hero-media">
          <div class="pf-hero-media-inner" id="pf-hero-media-inner">
            <img
              src={profileImage}
              alt={profileAlt}
              width="720"
              height="960"
              loading="eager"
              fetchpriority="high"
              id="pf-hero-img"
            />
          </div>
          {profileLink && (
            <a href={profileLink} class="pf-hero-media-link" aria-label="View my map"></a>
          )}
        </div>
      </div>
      <h1 class="pf-hero-name pf-serif">{name}</h1>
    </div>

    <!-- Tagline under the monument -->
    <p class="pf-hero-tagline pf-serif pf-hero-fadein">{taglineLine}</p>

    <!-- Bottom hairline row -->
    <div class="pf-hero-bottom pf-hero-fadein">
      <div class="pf-hero-desc">
        <p class="pf-grotesk">{description}</p>
        <p class="pf-hero-locations pf-grotesk">{locations}</p>
      </div>
      <div class="pf-hero-scroll" aria-hidden="true">
        <span class="pf-scroll-track"><span class="pf-scroll-dot"></span></span>
      </div>
    </div>
  </div>
</section>

<style>
  .pf-hero {
    position: relative;
    height: 100vh;
    height: 100dvh;
    min-height: 100vh;
    min-height: 100dvh;
    overflow: hidden;
  }

  /* Watermark */
  .pf-hero-watermark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }
  .pf-hero-watermark span {
    display: block;
    font-size: clamp(8rem, 24vw, 26rem);
    line-height: 1;
    letter-spacing: -0.04em;
    white-space: nowrap;
    color: var(--pf-text);
    opacity: 0.05;
  }

  /* Stage */
  .pf-hero-stage {
    position: relative;
    z-index: 1;
    height: 100%;
    max-width: 90rem;
    margin: 0 auto;
    padding: clamp(4.6rem, 10vh, 7rem) clamp(1.5rem, 5vw, 4rem) clamp(1.6rem, 4vh, 3rem);
    display: flex;
    flex-direction: column;
  }

  /* Kicker */
  .pf-hero-kicker {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    width: 100%;
    max-width: 36rem;
    margin: 0 auto;
  }
  .pf-hero-kicker span.pf-grotesk {
    font-size: clamp(0.7rem, 0.65rem + 0.25vw, 0.82rem);
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--pf-accent);
    white-space: nowrap;
  }
  .pf-hero-rule {
    flex: 1;
    height: 1px;
    background: var(--pf-border);
  }

  /* Center area — media in flow, words layered over it */
  .pf-hero-center {
    position: relative;
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(1rem, 2.4vh, 1.8rem);
    padding: clamp(0.8rem, 2.5vh, 2rem) 0;
  }

  .pf-hero-media-wrap {
    position: relative;
    height: min(52vh, calc(clamp(12.5rem, 25vw, 21rem) * 4 / 3));
    aspect-ratio: 3 / 4;
  }
  .pf-hero-media {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }
  .pf-hero-media-inner,
  .pf-hero-media-inner img {
    width: 100%;
    height: 100%;
  }
  .pf-hero-media-inner img {
    object-fit: cover;
    display: block;
    filter: saturate(0.82);
  }
  .pf-hero-media-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .pf-hero-name {
    margin: 0;
    font-weight: 400;
    text-align: center;
    line-height: 0.92;
    letter-spacing: -0.035em;
    font-size: clamp(2.8rem, 7vw, 6.8rem);
    color: var(--pf-text);
    white-space: nowrap;
    max-width: 100%;
  }

  /* Tagline */
  .pf-hero-tagline {
    margin: clamp(1.2rem, 3vh, 2.2rem) 0 clamp(1.4rem, 3.5vh, 2.6rem);
    font-style: italic;
    font-size: clamp(1.3rem, 1rem + 1.6vw, 2.1rem);
    letter-spacing: -0.01em;
    color: var(--pf-accent);
    text-align: center;
  }

  /* Bottom hairline row */
  .pf-hero-bottom {
    width: 100%;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2.5rem;
    border-top: 1px solid var(--pf-border);
    padding-top: clamp(1.2rem, 2.5vh, 2rem);
  }
  .pf-hero-desc { max-width: 26rem; }
  .pf-hero-desc p {
    margin: 0;
    font-size: clamp(0.95rem, 0.88rem + 0.4vw, 1.05rem);
    line-height: 1.6;
    color: var(--pf-text);
  }
  .pf-hero-locations {
    margin-top: 0.7rem !important;
    font-size: clamp(0.7rem, 0.66rem + 0.2vw, 0.78rem) !important;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pf-muted) !important;
  }

  .pf-hero-scroll { flex-shrink: 0; }
  .pf-scroll-track {
    display: block;
    width: 1px;
    height: 3.2rem;
    background: var(--pf-border);
    position: relative;
    overflow: hidden;
  }
  .pf-scroll-dot {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 1.1rem;
    background: var(--pf-accent);
    animation: pf-scroll-cue 2s var(--pf-ease) infinite;
  }
  @keyframes pf-scroll-cue {
    0% { transform: translateY(-1.2rem); }
    60%, 100% { transform: translateY(3.4rem); }
  }

  @media (prefers-reduced-motion: reduce) {
    .pf-scroll-dot { animation: none; }
  }

  /* Mobile */
  @media (max-width: 720px) {
    .pf-hero-media-wrap {
      height: min(46vh, calc(clamp(10.5rem, 50vw, 14rem) * 4 / 3));
    }
    .pf-hero-words {
      font-size: clamp(3.2rem, 18vw, 6.2rem);
      line-height: 0.84;
    }
    .pf-word-first { left: -0.34em; }
    .pf-word-last { left: 0.28em; }
    .pf-hero-scroll { display: none; }
    .pf-hero-tagline { font-size: clamp(1.15rem, 5vw, 1.5rem); }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function whenIntroDone(cb: () => void) {
    if (document.documentElement.classList.contains('pf-hold')) {
      document.addEventListener('pf:intro-done', cb, { once: true });
    } else {
      cb();
    }
  }

  function initHero() {
    const hero = document.getElementById('pf-hero');
    if (!hero || hero.dataset.gsapInit) return;
    hero.dataset.gsapInit = '1';

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const chars = hero.querySelectorAll('.pf-char');
    const media = document.getElementById('pf-hero-media');
    const mediaInner = document.getElementById('pf-hero-media-inner');
    const img = document.getElementById('pf-hero-img');
    const wordFirst = hero.querySelector('.pf-word-first');
    const wordLast = hero.querySelector('.pf-word-last');
    const watermark = document.getElementById('pf-hero-wm');

    if (reduced) return; // static hero, everything already visible

    // ── Entrance ──────────────────────────────────────
    gsap.set(chars, { yPercent: 120 });
    gsap.set(media, { clipPath: 'inset(100% 0% 0% 0%)' });
    gsap.set(img, { scale: 1.3, yPercent: 6 });

    whenIntroDone(() => {
      gsap.timeline({ defaults: { ease: 'expo.out' } })
        .to(media, { clipPath: 'inset(0% 0% 0% 0%)', duration: 1.4 }, 0.1)
        .to(img, { scale: 1.08, yPercent: 0, duration: 1.9 }, 0.1)
        .to(chars, { yPercent: 0, duration: 1.15, stagger: 0.04 }, 0.35);
    });

    // ── Scroll choreography — words part, portrait recedes ──
    gsap.timeline({
      scrollTrigger: { trigger: hero, start: 'top top', end: 'bottom top', scrub: 0.4 },
      defaults: { ease: 'none' },
    })
      .to(wordFirst, { xPercent: -22 }, 0)
      .to(wordLast, { xPercent: 22 }, 0)
      .to(media, { yPercent: -10 }, 0)
      .to(img, { scale: 1.18 }, 0);

    // ── Cursor lean — fine pointers only ──────────────
    if (window.matchMedia('(pointer: fine)').matches) {
      const leanX = mediaInner ? gsap.quickTo(mediaInner, 'x', { duration: 0.9, ease: 'power3.out' }) : null;
      const leanY = mediaInner ? gsap.quickTo(mediaInner, 'y', { duration: 0.9, ease: 'power3.out' }) : null;
      const wmX = watermark ? gsap.quickTo(watermark, 'x', { duration: 1.2, ease: 'power3.out' }) : null;
      const wmY = watermark ? gsap.quickTo(watermark, 'y', { duration: 1.2, ease: 'power3.out' }) : null;

      hero.addEventListener('mousemove', (e) => {
        const x = (e.clientX / window.innerWidth - 0.5) * 2;
        const y = (e.clientY / window.innerHeight - 0.5) * 2;
        leanX?.(x * -9); leanY?.(y * -9);
        wmX?.(x * 26); wmY?.(y * 14);
      }, { passive: true });

      hero.addEventListener('mouseleave', () => {
        leanX?.(0); leanY?.(0); wmX?.(0); wmY?.(0);
      });
    }
  }

  initHero();
  document.addEventListener('astro:after-swap', initHero);
</script>
