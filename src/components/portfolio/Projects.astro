---
/**
 * Projects.astro — card grid matching the resume timeline card style.
 * var(--pf-surface) background, 1px border, sienna hover tint.
 * Two columns on tablet, three on wide. Index number, serif title,
 * category, description, status dot, and links inside each card.
 */
import SectionHead from './SectionHead.astro';

interface ProjectLink {
  label: string;
  url: string;
}

interface Project {
  id: string;
  title: string;
  category: string;
  description: string;
  url?: string;
  links?: ProjectLink[];
  status: 'active' | 'coming-soon' | 'past';
}

interface Props {
  index: string;
  sectionTitle: string;
  projects: Project[];
  openLabel?: string;
  statusLabels?: {
    live: string;
    soon: string;
    archived: string;
  };
}

const {
  index,
  sectionTitle,
  projects,
  openLabel = 'Open Project',
  statusLabels = {
    live: 'Live',
    soon: 'Soon',
    archived: 'Archived',
  },
} = Astro.props;

const statusLabel = (status: Project['status']) =>
  status === 'active' ? statusLabels.live : status === 'coming-soon' ? statusLabels.soon : statusLabels.archived;
---

<section class="pf-section" aria-label={sectionTitle}>
  <div class="pf-section-inner">
    <SectionHead index={index} label={sectionTitle} title={sectionTitle} />

    <div class="pf-proj-grid">
      {projects.map((project, i) => {
        const links = project.links?.length
          ? project.links
          : project.url
            ? [{ label: openLabel, url: project.url }]
            : [];
        return (
          <article
            class="pf-proj-card"
            data-reveal
            style={`--reveal-delay:${Math.min(i % 6, 5) * 50}ms`}
          >
            <!-- Top row: index + status -->
            <div class="pf-proj-top">
              <span class="pf-proj-num pf-grotesk">{String(i + 1).padStart(2, '0')}</span>
              <span class:list={['pf-proj-status', 'pf-grotesk', `is-${project.status}`]}>
                <span class="pf-proj-status-dot" aria-hidden="true"></span>
                {statusLabel(project.status)}
              </span>
            </div>

            <!-- Category -->
            <span class="pf-proj-cat pf-grotesk">{project.category}</span>

            <!-- Title -->
            <h3 class="pf-proj-title pf-serif">{project.title}</h3>

            <!-- Description -->
            <p class="pf-proj-desc pf-grotesk">{project.description}</p>

            <!-- Links -->
            {project.status === 'active' && links.length > 0 && (
              <div class="pf-proj-links">
                {links.map((link) => (
                  <a
                    href={link.url}
                    target={link.url.startsWith('/') ? undefined : '_blank'}
                    rel={link.url.startsWith('/') ? undefined : 'noopener noreferrer'}
                    class="pf-proj-link pf-grotesk"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            )}
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .pf-section {
    padding: clamp(5rem, 12vh, 9rem) 0;
  }
  .pf-section-inner {
    max-width: 90rem;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  /* ── Grid ───────────────────────────────────────── */
  .pf-proj-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2vw, 1.4rem);
  }
  @media (min-width: 640px) {
    .pf-proj-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1100px) {
    .pf-proj-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Card — matches resume .pf-tl-card ─────────── */
  /* Card box is not clickable, so no hover highlight (links inside still react). */
  .pf-proj-card {
    background: var(--pf-surface);
    border: 1px solid var(--pf-border);
    padding: clamp(1.4rem, 2.5vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    position: relative;
  }

  /* ── Top row: index + status ────────────────────── */
  .pf-proj-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.3rem;
  }

  .pf-proj-num {
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    color: var(--pf-muted);
  }

  .pf-proj-status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .pf-proj-status.is-active   { color: var(--pf-accent); }
  .pf-proj-status.is-coming-soon,
  .pf-proj-status.is-past     { color: var(--pf-muted); }

  .pf-proj-status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
  }

  /* ── Category ───────────────────────────────────── */
  .pf-proj-cat {
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pf-muted);
  }

  /* ── Title ──────────────────────────────────────── */
  .pf-proj-title {
    font-size: clamp(1.4rem, 1rem + 1.6vw, 2.1rem);
    font-weight: 400;
    line-height: 1.06;
    letter-spacing: -0.02em;
    color: var(--pf-text);
    margin: 0.2rem 0 0.1rem;
  }

  /* ── Description ────────────────────────────────── */
  .pf-proj-desc {
    font-size: 0.88rem;
    line-height: 1.65;
    color: var(--pf-muted);
    margin: 0;
    flex: 1; /* push links to bottom */
  }

  /* ── Links ──────────────────────────────────────── */
  .pf-proj-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 1.2rem;
    border-top: 1px solid var(--pf-border);
    padding-top: 0.9rem;
    margin-top: 0.4rem;
  }
  .pf-proj-link {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pf-accent);
    text-decoration: none;
    position: relative;
  }
  .pf-proj-link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--pf-accent);
    transition: width 0.35s var(--pf-ease);
  }
  .pf-proj-link:hover::after { width: 100%; }
</style>
